# Copy to `.env` and fill in. Do not commit `.env`.
# Phase 3 (Google Drive) will read these. Leave blank until then.

# OAuth 2.0 credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Create an OAuth client of type "Desktop app".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Where the refresh token is cached after first successful auth.
# Relative paths are resolved against the platform's app-data dir
# (e.g. ~/Library/Application Support/Acher/ on macOS).
GOOGLE_OAUTH_TOKEN_PATH=token.json
